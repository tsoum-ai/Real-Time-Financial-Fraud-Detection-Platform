# Copy to .env before running. docker-compose reads this automatically.

# --- API ---
API_HOST=0.0.0.0
API_PORT=8000
LOG_LEVEL=INFO
APP_ENV=development

# --- Kafka ---
# Inside docker network use kafka:9092, from host use localhost:29092
KAFKA_BOOTSTRAP_SERVERS=kafka:9092
KAFKA_TRANSACTIONS_TOPIC=transactions
KAFKA_CLIENT_ID=fraud-platform

# --- MongoDB ---
MONGO_URI=mongodb://mongo:27017
MONGO_DB=fraud_platform
MONGO_TRANSACTIONS_COLLECTION=transactions
MONGO_FRAUDS_COLLECTION=fraud_alerts

# --- Spark ---
SPARK_CHECKPOINT_DIR=/tmp/spark-checkpoints
SPARK_MAX_OFFSETS_PER_TRIGGER=1000

# --- Fraud rules (tunable thresholds) ---
FRAUD_AMOUNT_THRESHOLD=10000
FRAUD_RAPID_TXN_WINDOW_SECONDS=60
FRAUD_RAPID_TXN_COUNT=5
# comma separated ISO country codes considered high risk
FRAUD_HIGH_RISK_COUNTRIES=NG,RU,KP,IR,SY

# --- Generator (optional, used by the standalone producer) ---
GEN_INTERVAL_SECONDS=1.0
GEN_FRAUD_RATIO=0.15
